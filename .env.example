# RecallPlate — Environment Variables
#
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.

# ──────────────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string. Supports Supabase, Neon, Railway, or any PG host.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/recallplate?sslmode=require"

# ──────────────────────────────────────────────────────────────────────────────
# External APIs
# ──────────────────────────────────────────────────────────────────────────────

# openFDA API key (free). Get one at: https://open.fda.gov/apis/authentication/
# Without a key: 40 requests/minute. With a key: 240 requests/minute.
OPENFDA_API_KEY="your-openfda-api-key"

# Anthropic API key for Claude AI summary generation during ETL.
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-api03-your-key-here"

# ──────────────────────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────────────────────

# Public base URL (used for OG images, canonical URLs, sitemap).
# Local development: http://localhost:3000
# Production: https://recallplate.com
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Secret token to authenticate cron job requests (ETL trigger).
# Generate with: openssl rand -base64 32
CRON_SECRET="generate-a-strong-random-secret-at-least-16-chars"
